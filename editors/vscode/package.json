{
  "name": "lute",
  "displayName": "Lute",
  "description": "Language support for the Lute scenario-authoring DSL (.lute): diagnostics, hover, completion, go-to-definition, references, folding, symbols, and highlighting via the lute-lsp language server.",
  "version": "0.7.0",
  "publisher": "lute-lang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/journeyWorker/lute.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "lute",
    "scenario",
    "visual-novel",
    "dsl"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:lute"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lute",
        "aliases": [
          "Lute",
          "lute"
        ],
        "extensions": [
          ".lute"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lute",
        "scopeName": "source.lute",
        "path": "./syntaxes/lute.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Lute",
      "properties": {
        "lute.lsp.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `lute-lsp` language server binary. When empty, the extension resolves `lute-lsp` from your `PATH`."
        }
      }
    },
    "semanticTokenTypes": [
      { "id": "content", "description": "Dialogue / narration text" },
      { "id": "staging", "description": "Staging directive" },
      { "id": "logic", "description": "Logic/timeline tag" },
      { "id": "cel", "description": "CEL condition" },
      { "id": "ref", "description": "Def / param reference" },
      { "id": "statePath", "description": "State path" }
    ],
    "semanticTokenScopes": [
      {
        "language": "lute",
        "scopes": {
          "content": ["string.unquoted.dialogue.lute"],
          "staging": ["entity.name.function.directive.lute"],
          "logic": ["entity.name.tag.lute"],
          "cel": ["meta.embedded.cel.lute"],
          "ref": ["variable.other.ref.lute"],
          "statePath": ["variable.other.path.lute"]
        }
      }
    ],
    "configurationDefaults": {
      "yaml.schemas": {
        "schemas/lute.schema.json": "**/*.schema.yaml",
        "schemas/lute.plugin.json": "**/plugins/**/*.yaml"
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo \"lute: no build step (plain JS)\"",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
