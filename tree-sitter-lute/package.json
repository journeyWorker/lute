{
  "name": "tree-sitter-lute",
  "version": "0.0.1",
  "description": "Tree-sitter grammar for the Lute Scenario DSL (editor-side: highlighting/folding host, not the authoritative AST)",
  "metadata": {
    "capabilityVersion": "b5187e53c769059a2413754ad831064a0383b51f79a4fbed268f2b484361f29d"
  },
  "license": "MIT",
  "keywords": [
    "tree-sitter",
    "parser",
    "lute",
    "scenario-dsl"
  ],
  "main": "bindings/node",
  "tree-sitter": [
    {
      "scope": "source.lute",
      "file-types": [
        "lute"
      ],
      "injection-regex": "^lute$"
    }
  ],
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "tree-sitter-cli": "^0.26.0"
  }
}
