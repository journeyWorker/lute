---
kind: scene
character: demo
season: 1
episode: 3
state:
  scene.score: { type: number, default: 0 }
  scene.flag: { type: bool, default: false }
defs:
  atLeast: { type: bool, params: { n: number }, cel: "scene.score >= 1" }
---

## Shot 1.

<match on="scene.flag">
  <when test="@atLeast(3)">
  @narrator: high enough
</when>
  <otherwise>
  @narrator: not yet
</otherwise>
</match>
